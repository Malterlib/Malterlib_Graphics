%Target "Tool_libjpeg-turbo_tjdoc"
{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/libjpeg-turbo"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "libjpeg-turbo_tjdoc"
	Target.BaseFileName "tjdoc"
	%Group "Windows"
	{
		%Group "arm64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "CMakeFiles"
				{
					%File `@('.'->MakeAbsolute())/CMakeFiles/tjdoc.rule`
					{
						Compile
						{
							Type "Custom"
							Custom_CommandLine `doxygen -s ../doc/doxygen.config`
							AllowNonExisting true
							Disabled false
							Custom_WorkingDirectory `@('../../../../External/libjpeg-turbo'->MakeAbsolute())/src`->MakeAbsolute()
							Custom_Outputs []
							Custom_Inputs []
						}
					}
				}
			}
		}
	}
}

%Target "Com_libjpeg-turbo_tjunittest-static"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('.'->MakeAbsolute())`->MakeAbsolute(),
			`@('../../../../External/libjpeg-turbo'->MakeAbsolute())/src`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"NEON_INTRINSICS",
			"_CRT_NONSTDC_NO_WARNINGS"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/libjpeg-turbo"
	{
		!!Target.Group undefined
	}
	Target.Type "ConsoleExecutable"
	Target.BaseName "libjpeg-turbo_tjunittest-static"
	Target.BaseFileName "tjunittest-static"
	%Group "src"
	{
		%File `@('../../../../External/libjpeg-turbo'->MakeAbsolute())/src/tjunittest.c`
		{
			Compile.Type "C"
		}
		%File `@('../../../../External/libjpeg-turbo'->MakeAbsolute())/src/tjutil.c`
		{
			Compile.Type "C"
		}
		%Group "md5"
		{
			%File `@('../../../../External/libjpeg-turbo'->MakeAbsolute())/src/md5/md5.c`
			{
				Compile.Type "C"
			}
			%File `@('../../../../External/libjpeg-turbo'->MakeAbsolute())/src/md5/md5hl.c`
			{
				Compile.Type "C"
			}
		}
	}
	%Dependency "Lib_libjpeg-turbo_turbojpeg-static"
}
